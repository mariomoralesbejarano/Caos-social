# =============================================================================
# CAOS SOCIAL · Variables de entorno
# =============================================================================
# Copia este fichero a `.env` (y a las variables de entorno de tu proveedor
# de despliegue) y rellena los valores. NUNCA subas tu `.env` real al
# repositorio.

# -----------------------------------------------------------------------------
# Servidor de la API (artifacts/api-server)
# -----------------------------------------------------------------------------

# Puerto en el que escucha el servidor Express. En la mayoría de proveedores
# (Render, Railway, Fly.io, Heroku, Replit Deployments) lo asignan ellos
# automáticamente.
PORT=8080

# Entorno de ejecución. Usa "production" en despliegues reales.
NODE_ENV=production

# Nivel de logs de Pino: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# App móvil / web (artifacts/caos-social)
# -----------------------------------------------------------------------------

# Dominio público (sin protocolo) donde está alojada la API. La app Expo
# antepone https:// y llama a `https://<EXPO_PUBLIC_DOMAIN>/api/...`
# Ejemplo: caos-social-api.tu-dominio.com
EXPO_PUBLIC_DOMAIN=

# Ruta base donde se sirve el bundle web de Expo. Déjalo en "/" salvo que
# montes la app en un subdirectorio.
BASE_PATH=/

# -----------------------------------------------------------------------------
# Solo para entorno Replit (no necesarios fuera de Replit)
# -----------------------------------------------------------------------------
# REPLIT_DEV_DOMAIN=
# REPLIT_EXPO_DEV_DOMAIN=
# REPL_ID=
# SESSION_SECRET=
